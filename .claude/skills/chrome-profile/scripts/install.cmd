@echo off
REM install.cmd -- install the chrome-profile CLI shim onto PATH on Windows.
REM
REM Creates a small shim at %PREFIX%\bin\chrome-profile.cmd that invokes the
REM bundled Python CLI. Idempotent. Default prefix is %USERPROFILE%\.local.
REM
REM Usage:
REM   install.cmd                              install to %USERPROFILE%\.local\bin
REM   set PREFIX=C:\tools && install.cmd       custom prefix

setlocal

set "SCRIPT_DIR=%~dp0"
if "%SCRIPT_DIR:~-1%"=="\" set "SCRIPT_DIR=%SCRIPT_DIR:~0,-1%"
set "CLI=%SCRIPT_DIR%\chrome_profile_cli.py"

if not exist "%CLI%" (
  echo install.cmd: cannot find %CLI%
  exit /b 1
)

where python >nul 2>&1
if errorlevel 1 (
  where py >nul 2>&1
  if errorlevel 1 (
    echo install.cmd: neither 'python' nor 'py' on PATH. Install Python 3.9+ first.
    exit /b 1
  )
  set "PY=py -3"
) else (
  set "PY=python"
)

if "%PREFIX%"=="" set "PREFIX=%USERPROFILE%\.local"
set "BIN_DIR=%PREFIX%\bin"
if not exist "%BIN_DIR%" mkdir "%BIN_DIR%"

set "SHIM=%BIN_DIR%\chrome-profile.cmd"
> "%SHIM%" echo @echo off
>> "%SHIM%" echo REM auto-generated by chrome-profile install.cmd
>> "%SHIM%" echo %PY% "%CLI%" %%*

echo [+] installed: %SHIM% -^> %CLI%

echo %PATH% | findstr /I /C:"%BIN_DIR%" >nul
if errorlevel 1 (
  echo [!] %BIN_DIR% is not on PATH. Add it once, then reopen your terminal:
  echo     setx PATH "%%PATH%%;%BIN_DIR%"
)

echo [*] next: chrome-profile setup
endlocal
